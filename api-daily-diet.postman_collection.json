            "description": "Retorna os dados de uma refeição específica pelo ID. Requer cookie de sessão (sessionId)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"meal\": {\n    \"id\": \"uuid-da-refeicao\",\n    \"session_id\": \"uuid-da-sessao\",\n    \"name\": \"Almoço saudável\",\n    \"description\": \"Frango grelhado com arroz integral e salada\",\n    \"date_time\": \"2026-05-31T12:00:00.000Z\",\n    \"on_diet\": 1\n  }\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
