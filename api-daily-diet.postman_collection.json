          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [
                {
                  "key": "Content-Type",
                  "value": "application/json"
                }
              ],
              "body": "{\n  \"summary\": {\n    \"totalMeals\": 10,\n    \"totalOnDiet\": 7,\n    \"totalNotOnDiet\": 3,\n    \"bestSequence\": 5\n  }\n}"
