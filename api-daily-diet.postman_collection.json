        {
          "name": "Deletar refeição",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/meals/{{mealId}}",
              "host": ["{{baseUrl}}"],
              "path": ["meals", "{{mealId}}"]
            },
            "description": "Remove uma refeição pelo ID."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": ""
