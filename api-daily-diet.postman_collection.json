        {
          "name": "Resumo da dieta",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/meals/summary",
              "host": ["{{baseUrl}}"],
              "path": ["meals", "summary"]
